# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...

# Deal validity gate before Slack
DEAL_VALIDITY_MAX_AGE_DAYS=7
DEAL_VALIDITY_URL_CONCURRENCY=8
URL_CHECK_TIMEOUT_MS=7000
DEAL_VALIDITY_REQUIRE_VIENNA=1
# 0=Sunday, 1=Monday, ... 6=Saturday. Default: Monday.
DEAL_VALIDITY_CHURCH_WEEKDAY=1

# Instagram auth (optional but strongly recommended for better coverage)
# Option A: direct session id value
INSTAGRAM_SESSIONID=
INSTAGRAM_COOKIES=
INSTAGRAM_AUTH_TEST_USERNAME=instagram
INSTAGRAM_AUTH_SLACK_DEDUP_HOURS=6
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
# Optional if the Instagram account has app-based 2FA enabled (Base32 TOTP secret)
INSTAGRAM_TOTP_SECRET=
# Optional one-time fallback for manual Instagram email verification
INSTAGRAM_EMAIL_CODE=
# Fine-grained GitHub PAT with repository Actions secrets write permission
GH_SECRETS_PAT=

# Gmail API for automatic Instagram email verification codes.
# Use OAuth with Gmail readonly scope, never a Gmail password.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_ID=me
GMAIL_OAUTH_REDIRECT_URI=http://localhost:3000/oauth2callback
GMAIL_INSTAGRAM_CODE_QUERY=
GMAIL_INSTAGRAM_CODE_POLL_TIMEOUT_MS=90000
GMAIL_INSTAGRAM_CODE_POLL_INTERVAL_MS=5000

# Option B: path to cookie file (newline or semicolon separated key=value pairs)
# Example: /Users/Stefan/Downloads/deal-finder-main-9/instagram.cookies
INSTAGRAM_COOKIES_FILE=

# Apify Instagram Actor
APIFY_TOKEN=
APIFY_INSTAGRAM_VIENNA_ACTOR_ID=
APIFY_INSTAGRAM_COOKIE_STRING=
APIFY_INSTAGRAM_SESSIONID=
