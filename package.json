{
  "name": "freefinder-wien",
  "version": "2.3.0",
  "description": "Wien Deals & Freebies Finder",
  "type": "module",
  "scripts": {
    "scrape": "node scraper/power-scraper.js",
    "firecrawl": "node scraper/firecrawl-consumables.js",
    "firecrawl4": "node scraper/firecrawl-instagram-direct4.js",
    "firecrawl5": "node scraper/firecrawl-instagram-gastro5.js",
    "firecrawl-consumables": "node scraper/firecrawl-consumables.js",
    "gastro2": "node scraper/firecrawl-gastro2.js",
    "food3": "node scraper/firecrawl-food3.js",
    "google-deals": "node scraper/google-deals-scraper.js",
    "joe": "node scraper/joe-scraper.js",
    "joe:auth:save": "node scripts/save-joe-auth-state.mjs",
    "joe:auth:load": "node scripts/load-joe-auth-state.mjs",
    "gutscheine": "node scraper/gutscheine-scraper.js",
    "instagram": "node scraper/instagram-web-scraper.js",
    "instagram:discovery": "node scraper/instagram-discovery-scraper.js",
    "instagram:check": "node scripts/check-instagram-auth.mjs",
    "filter-old": "node scraper/filter-old-deals.js",
    "slack-notify": "node scraper/slack-notify.js",
    "slack-approve": "node scraper/slack-approve.js",
    "smart-summary": "node scraper/smart-summary.js",
    "scrape-all": "npm run scrape && npm run firecrawl4 && npm run firecrawl-consumables && npm run gastro2 && npm run food3 && npm run firecrawl5 && npm run google-deals && npm run joe && npm run gutscheine && npm run instagram:discovery && npm run filter-old && npm run slack-notify",
    "sync:fresh": "npm run scrape-all && npm run ios:shot",
    "ios:install": "playwright install webkit",
    "ios:shot": "node scripts/ios-screenshot.mjs"
  },
  "author": "FreeFinder",
  "license": "MIT",
  "dependencies": {
    "@mendable/firecrawl-js": "^4.12.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
